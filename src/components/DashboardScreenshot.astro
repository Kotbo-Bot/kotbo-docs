---
interface Props {
  file: string;
  alt: string;
  caption?: string;
  eager?: boolean;
}

const { file, alt, caption, eager = false } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const src = `${basePath}screenshots/${file}`;
---

<figure class="dashboard-screenshot">
  <a href={src} target="_blank" rel="noreferrer" aria-label={`${alt} — ouvrir en taille réelle`}>
    <span class="screen-label"><i></i> Interface réelle · données de démonstration</span>
    <img src={src} alt={alt} loading={eager ? 'eager' : 'lazy'} decoding="async" />
    <span class="screen-zoom" aria-hidden="true">Agrandir ↗</span>
  </a>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .dashboard-screenshot { margin: 1.8rem 0 2.5rem; }
  .dashboard-screenshot > a {
    position: relative;
    display: block;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 55%, transparent);
    border-radius: 1rem;
    background: #09090b;
    box-shadow: 0 24px 65px color-mix(in srgb, #001421 24%, transparent), 0 1px 0 #fff1 inset;
  }
  .dashboard-screenshot img { display: block; width: 100%; height: auto; margin: 0; }
  .screen-label {
    position: absolute;
    z-index: 1;
    top: .75rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: .42rem;
    white-space: nowrap;
    padding: .36rem .62rem;
    border: 1px solid #ffffff16;
    border-radius: 999px;
    background: #090b0edb;
    backdrop-filter: blur(10px);
    color: #aab5bd;
    font-size: .59rem;
    font-weight: 750;
    letter-spacing: .06em;
    text-transform: uppercase;
  }
  .screen-label i { width: .38rem; height: .38rem; border-radius: 50%; background: #2bd5a4; box-shadow: 0 0 0 3px #2bd5a41c; }
  .screen-zoom {
    position: absolute;
    right: .75rem;
    bottom: .75rem;
    padding: .42rem .65rem;
    border-radius: .5rem;
    background: #080b0dde;
    color: #e2edf1;
    font-size: .64rem;
    font-weight: 700;
    opacity: 0;
    transform: translateY(4px);
    transition: .2s ease;
  }
  .dashboard-screenshot > a:hover .screen-zoom { opacity: 1; transform: none; }
  .dashboard-screenshot figcaption { margin-top: .7rem; text-align: center; color: var(--sl-color-gray-3); font-size: .74rem; }
  @media (max-width: 600px) {
    .dashboard-screenshot { margin-inline: -0.4rem; }
    .screen-label { top: .45rem; font-size: .46rem; }
    .screen-zoom { display: none; }
  }
</style>
