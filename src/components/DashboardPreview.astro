---
interface Props {
  mode?: 'overview' | 'welcome' | 'modules';
  compact?: boolean;
}

const { mode = 'overview', compact = false } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const nav = [
  ['⌂', "Vue d’ensemble"],
  ['◉', 'Analytics'],
  ['♙', 'Membres'],
  ['◇', 'Sanctions'],
  ['✦', 'Accueil & Départ'],
  ['▦', 'Modules'],
];
---

<div class:list={['dashboard-shot', `is-${mode}`, { compact }]} aria-label={`Aperçu du dashboard Kotbo — ${mode}`}>
  <div class="shot-glow"></div>
  <div class="browser-bar">
    <span></span><span></span><span></span>
    <div class="address">dashboard.kotbo.fr</div>
  </div>
  <div class="dashboard-shell">
    <aside>
      <div class="brand"><img src={`${basePath}favicon.svg`} alt="" /><b>Kotbo</b></div>
      <small>GÉNÉRAL</small>
      {nav.slice(0, 4).map(([icon, label], i) => <div class:list={['nav-row', { active: mode === 'overview' && i === 0 }]}><span>{icon}</span>{label}</div>)}
      <small>COMMUNAUTÉ</small>
      <div class:list={['nav-row', { active: mode === 'welcome' }]}><span>✦</span>Accueil & Départ</div>
      <small>CONFIGURATION</small>
      <div class:list={['nav-row', { active: mode === 'modules' }]}><span>▦</span>Modules</div>
    </aside>
    <section class="dash-main">
      <header>
        <button class="server"><i>KS</i><span>Kotbo Server</span><b>⌄</b></button>
        <div class="user-tools"><span>☼</span><span>●</span><i>NA</i></div>
      </header>
      {mode === 'overview' && (
        <main>
          <div class="page-heading"><div><small>MARDI 30 JUIN</small><h2>Bonjour Nathan 👋</h2><p>Voici ce qu’il se passe sur votre serveur.</p></div><button>Modifier la disposition</button></div>
          <div class="metric-grid">
            <article><span class="metric-icon blue">♙</span><small>MEMBRES</small><strong>12 842</strong><em>+126 ce mois</em></article>
            <article><span class="metric-icon green">◉</span><small>EN LIGNE</small><strong>1 204</strong><em>842 actifs</em></article>
            <article><span class="metric-icon cyan">◌</span><small>EN VOCAL</small><strong>87</strong><em>maintenant</em></article>
            <article><span class="metric-icon amber">↗</span><small>CROISSANCE 7J</small><strong>+4,8%</strong><em>en progression</em></article>
          </div>
          <div class="lower-grid"><article class="chart"><div><b>Activité du serveur</b><small>7 derniers jours</small></div><svg viewBox="0 0 420 110" preserveAspectRatio="none"><path d="M0 91 C45 80, 70 92, 110 65 S175 75, 215 44 S290 70, 330 31 S385 45, 420 14" fill="none" stroke="#24bdcf" stroke-width="4"/><path d="M0 91 C45 80,70 92,110 65 S175 75,215 44 S290 70,330 31 S385 45,420 14 L420 110 L0 110Z" fill="url(#chartfill)" opacity=".25"/><defs><linearGradient id="chartfill" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#24bdcf"/><stop offset="1" stop-color="#24bdcf" stop-opacity="0"/></linearGradient></defs></svg></article><article class="activity"><b>Activité récente</b><p><i class="dot green"></i>Nouveau membre rejoint</p><p><i class="dot blue"></i>Module mis à jour</p><p><i class="dot amber"></i>Sauvegarde terminée</p></article></div>
        </main>
      )}
      {mode === 'welcome' && (
        <main>
          <div class="module-title"><span>✦</span><div><h2>Accueil & Départ</h2><p>Configurez les messages automatiques de votre serveur.</p></div></div>
          <div class="variable-bar"><b>Variables disponibles</b><code>{'{user}'}</code><code>{'{username}'}</code><code>{'{server}'}</code><code>{'{memberCount}'}</code></div>
          <div class="welcome-grid">
            <article><div class="card-title"><b>Message de bienvenue</b><i class="toggle on"></i></div><label>SALON DE DIFFUSION</label><div class="field"># bienvenue <span>⌄</span></div><label>CONTENU DU MESSAGE</label><div class="field multiline">Bienvenue {`{user}`} sur {`{server}`} !<br/>Nous sommes maintenant {`{memberCount}`}.</div><label>APERÇU DISCORD</label><div class="discord-preview"><i>K</i><p><b>Kotbo <small>BOT</small></b><br/>Bienvenue <mark>@JeanDupont</mark> sur Kotbo Server !</p></div></article>
            <article class="leave-card"><div class="card-title"><b>Message de départ</b><i class="toggle"></i></div><p class="muted-center">Activez ce message pour prévenir votre communauté lorsqu’un membre quitte le serveur.</p></article>
          </div>
          <div class="save-row"><span>Modifications non enregistrées</span><button>Enregistrer</button></div>
        </main>
      )}
      {mode === 'modules' && (
        <main>
          <div class="page-heading"><div><small>CONFIGURATION</small><h2>Modules</h2><p>Activez uniquement les fonctions utiles à votre communauté.</p></div></div>
          <div class="module-grid">
            {[
              ['🛡', 'Modération', 'Sanctions, sécurité et journaux', true],
              ['🏆', 'Leveling & XP', 'Niveaux, récompenses et classement', true],
              ['🪙', 'Économie & RPG', 'Monnaie, boutique et quêtes', false],
              ['🎟', 'Tickets', 'Support et suivi de satisfaction', true],
              ['🎉', 'Giveaways', 'Concours automatisés', false],
              ['↗', 'Accueil & Départ', 'Messages pour vos membres', true],
            ].map(([icon, title, desc, enabled]) => <article><span>{icon}</span><div><b>{title}</b><p>{desc}</p></div><i class:list={['toggle', { on: enabled }]}></i></article>)}
          </div>
        </main>
      )}
    </section>
  </div>
</div>

<style>
  .dashboard-shot{position:relative;overflow:hidden;border:1px solid color-mix(in srgb,var(--sl-color-white) 12%,transparent);border-radius:18px;background:#07111d;box-shadow:0 28px 80px #00101f66,0 2px 0 #fff1 inset;color:#dce8ef;font-family:Manrope,ui-sans-serif,sans-serif;isolation:isolate}.shot-glow{position:absolute;width:48%;aspect-ratio:1;right:-12%;top:-35%;background:#20c4d433;filter:blur(75px);z-index:-1}.browser-bar{height:37px;display:flex;align-items:center;gap:6px;padding:0 13px;background:#0b1724;border-bottom:1px solid #ffffff0d}.browser-bar>span{width:7px;height:7px;border-radius:50%;background:#375064}.browser-bar>span:first-child{background:#f16666}.browser-bar>span:nth-child(2){background:#e6b85d}.browser-bar>span:nth-child(3){background:#65c580}.address{margin:auto;width:36%;height:19px;border-radius:5px;background:#ffffff08;color:#688093;font-size:7px;display:grid;place-items:center}.dashboard-shell{display:grid;grid-template-columns:154px 1fr;min-height:480px}.dashboard-shell aside{background:#081522;border-right:1px solid #ffffff0d;padding:15px 11px}.brand{display:flex;align-items:center;gap:8px;margin-bottom:18px;padding:0 5px;font-size:12px}.brand img{width:25px;height:25px}.dashboard-shell aside small{font-size:6px;color:#556b7b;letter-spacing:.15em;display:block;margin:15px 7px 6px}.nav-row{height:28px;border-radius:6px;display:flex;align-items:center;gap:8px;color:#8095a5;font-size:8px;padding:0 8px;margin:2px 0}.nav-row>span{width:12px;text-align:center;color:#617989}.nav-row.active{background:#1ab8ca17;color:#e5fbfd}.nav-row.active>span{color:#26c6d7}.dash-main{min-width:0;background:#0b1825}.dash-main>header{height:46px;padding:0 18px;border-bottom:1px solid #ffffff0b;display:flex;align-items:center;justify-content:space-between;background:#0c1926}.server{height:26px;border:1px solid #ffffff12;background:#111f2d;border-radius:6px;color:#93a8b7;font-size:8px;display:flex;align-items:center;gap:7px;padding:0 9px}.server i,.user-tools i{display:grid;place-items:center;width:16px;height:16px;border-radius:4px;background:#1b6b82;color:#dffbff;font-size:6px;font-style:normal}.server b{font-weight:400;color:#556c7c}.user-tools{display:flex;align-items:center;gap:10px;color:#607888;font-size:9px}.user-tools i{width:23px;height:23px;border-radius:6px;background:linear-gradient(145deg,#416579,#1e3545)}.dash-main main{padding:23px}.page-heading{display:flex;align-items:end;justify-content:space-between;margin-bottom:17px}.page-heading small{font-size:6px;letter-spacing:.16em;color:#23bdcf;font-weight:700}.page-heading h2,.module-title h2{margin:3px 0 2px;color:#eff7f9;font-size:16px;line-height:1.2;letter-spacing:-.03em}.page-heading p,.module-title p{margin:0;color:#718797;font-size:8px}.page-heading button,.save-row button{border:1px solid #25b9ca55;background:#1ab5c31a;color:#4cd6e4;border-radius:6px;padding:7px 10px;font-size:7px}.metric-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px}.metric-grid article{border:1px solid #ffffff0d;background:#0e1d2b;border-radius:9px;padding:12px;display:grid;grid-template-columns:25px 1fr;column-gap:8px}.metric-icon{grid-row:1/4;width:24px;height:24px;display:grid;place-items:center;border-radius:6px;font-style:normal;font-size:10px}.metric-icon.blue{background:#4487ff19;color:#6098ff}.metric-icon.green{background:#35c88418;color:#4ed79a}.metric-icon.cyan{background:#22c5d718;color:#35cbd9}.metric-icon.amber{background:#f0b84918;color:#efbc55}.metric-grid small{font-size:5.5px;letter-spacing:.1em;color:#647a8a}.metric-grid strong{font-size:13px;line-height:1.3;color:#e5eff3}.metric-grid em{font-size:6px;color:#587080;font-style:normal}.lower-grid{display:grid;grid-template-columns:1.65fr 1fr;gap:9px;margin-top:9px}.lower-grid article{border:1px solid #ffffff0d;background:#0e1d2b;border-radius:9px;padding:13px}.chart>div{display:flex;justify-content:space-between}.chart b,.activity b{font-size:8px}.chart small{font-size:6px;color:#617889}.chart svg{width:100%;height:100px;margin-top:10px}.activity p{font-size:7px;color:#718796;border-bottom:1px solid #ffffff0a;padding:9px 0;margin:0}.dot{display:inline-block;width:5px;height:5px;border-radius:50%;margin-right:6px}.dot.green{background:#48cf92}.dot.blue{background:#4b8ff0}.dot.amber{background:#e7b450}.module-title{display:flex;gap:10px;align-items:center;margin-bottom:14px}.module-title>span{width:32px;height:32px;border-radius:8px;display:grid;place-items:center;background:#1fc1d218;color:#32cbd9}.variable-bar{display:flex;align-items:center;gap:7px;background:#0e1e2c;border:1px solid #ffffff0d;border-radius:8px;padding:10px;margin-bottom:10px;font-size:7px}.variable-bar b{margin-right:auto}.variable-bar code{font-size:6px;padding:3px 5px;border-radius:4px;color:#3fd2de;background:#2bc7d414}.welcome-grid{display:grid;grid-template-columns:1.35fr .65fr;gap:10px}.welcome-grid article{border:1px solid #ffffff0d;background:#0e1d2b;border-radius:9px;padding:14px}.card-title{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #ffffff0b;padding-bottom:10px;margin-bottom:10px;font-size:9px}.toggle{display:inline-block;width:22px;height:12px;border-radius:20px;background:#314352;position:relative;flex:none}.toggle:after{content:'';position:absolute;width:8px;height:8px;top:2px;left:2px;background:#8093a1;border-radius:50%;transition:.2s}.toggle.on{background:#1fb8c8}.toggle.on:after{left:12px;background:white}.welcome-grid label{display:block;font-size:5.5px;color:#687d8c;letter-spacing:.1em;margin:9px 0 4px}.field{min-height:24px;border-radius:5px;border:1px solid #ffffff0e;background:#111f2d;color:#a5b5c0;font-size:7px;padding:7px;display:flex;justify-content:space-between}.field.multiline{height:39px;display:block;line-height:1.7}.discord-preview{display:flex;gap:7px;border-radius:6px;background:#111f2d;padding:9px;font-size:6.5px;color:#a9b8c3}.discord-preview>i{width:22px;height:22px;border-radius:50%;display:grid;place-items:center;background:#103d54;color:#35c9d8;font-style:normal}.discord-preview p{margin:0;line-height:1.6}.discord-preview small{background:#4280b2;color:white;padding:1px 2px;border-radius:2px}.discord-preview mark{background:none;color:#66c9da}.muted-center{text-align:center;color:#667c8c;font-size:7px;line-height:1.6;margin:70px 12px}.save-row{display:flex;align-items:center;justify-content:flex-end;gap:10px;margin-top:10px;color:#e6b75a;font-size:7px}.module-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:9px}.module-grid article{display:flex;align-items:center;gap:10px;border:1px solid #ffffff0d;background:#0e1d2b;border-radius:9px;padding:12px}.module-grid article>span{width:29px;height:29px;border-radius:7px;background:#ffffff08;display:grid;place-items:center;font-size:13px}.module-grid article>div{flex:1}.module-grid b{display:block;font-size:8px}.module-grid p{margin:2px 0 0;font-size:6px;color:#647b8b}.compact .dashboard-shell{min-height:370px}.compact .dash-main main{padding:17px}.compact .dashboard-shell{grid-template-columns:128px 1fr}
  @media(max-width:700px){.dashboard-shell{grid-template-columns:1fr;min-height:360px}.dashboard-shell aside{display:none}.dash-main main{padding:13px}.metric-grid{grid-template-columns:repeat(2,1fr)}.lower-grid,.welcome-grid{grid-template-columns:1fr}.activity,.leave-card{display:none}.browser-bar{height:29px}.module-grid{grid-template-columns:1fr}.page-heading button{display:none}.variable-bar{overflow:hidden}.variable-bar code:nth-last-child(-n+2){display:none}}
</style>
